# SQLite database file (relative to prisma/schema.prisma)
DATABASE_URL="file:./dev.db"

# API port
PORT=3001

# Optional: allow only your Vite dev origin (default: all origins in dev)
# CORS_ORIGIN=http://localhost:5173

# Optional: override default admin password when seeding (default: Admin3msu)
# SEED_ADMIN_PASSWORD=

# Optional: max JSON body size (profile pictures are sent as base64)
# JSON_BODY_LIMIT=15mb

# GabAI — text uses Groq (server-side key); images/files use local Ollama
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Ollama — vision + document extraction (when user attaches image or file)
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_VISION_MODEL=llava
# OLLAMA_TEXT_MODEL=llama3.2
# If you only pulled llava, set OLLAMA_TEXT_MODEL=llava
# Keep models loaded between requests (faster follow-up attachment analysis)
# OLLAMA_KEEP_ALIVE=15m
# GABAI_MAX_DOC_CHARS=48000
